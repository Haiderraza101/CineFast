<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <RelativeLayout
            android:layout_marginTop="40dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSummaryBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@android:color/transparent"
                android:padding="0dp"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                app:icon="@drawable/ic_back_arrow"
                app:iconTint="@color/text_white"
                app:iconSize="24dp"
                app:iconGravity="textStart"
                android:layout_centerVertical="true" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Booking Summary"
                android:textColor="@color/text_white"
                android:textSize="18sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="32dp">

            <androidx.cardview.widget.CardView
                android:layout_width="100dp"
                android:layout_height="140dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/card_mid">
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivFinalMoviePoster"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    app:shapeAppearanceOverlay="@style/RoundedIcon"
                    android:src="@drawable/interstellar" />
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="20dp"
                android:layout_gravity="center_vertical">

                <TextView
                    android:id="@+id/tvFinalMovieName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Movie Name"
                    android:textColor="@color/text_white"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <TextView
                        android:id="@+id/tvage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@color/snack_popcorn"
                        android:paddingHorizontal="6dp"
                        android:text="+13"
                        android:textColor="@color/text_white"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="IMAX 2D"
                        android:textColor="@color/text_placeholder"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="4"
            android:layout_marginBottom="24dp">

            <LinearLayout android:layout_height="wrap_content" android:orientation="vertical" android:layout_width="0dp" android:layout_weight="1">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hall" android:textColor="@color/text_label" android:textSize="10sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:id="@+id/tvhallNumber" android:text="1" android:textColor="@color/text_white" android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout android:layout_height="wrap_content" android:orientation="vertical" android:layout_width="0dp" android:layout_weight="1">
                <TextView android:layout_height="wrap_content" android:layout_width="wrap_content" android:text="Date" android:textColor="@color/text_label" android:textSize="10sp"/>
                <TextView android:layout_height="wrap_content" android:layout_width="wrap_content" android:id="@+id/tvdate" android:text="12/12" android:textColor="@color/text_white" android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout android:layout_height="wrap_content" android:orientation="vertical" android:layout_width="0dp" android:layout_weight="1">
                <TextView android:layout_height="wrap_content" android:layout_width="wrap_content" android:text="Time" android:textColor="@color/text_label" android:textSize="10sp"/>
                <TextView android:layout_height="wrap_content" android:layout_width="wrap_content" android:id="@+id/tvtime" android:text="10:00" android:textColor="@color/text_white" android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout android:layout_height="wrap_content" android:orientation="vertical" android:layout_width="0dp" android:layout_weight="1">
                <TextView android:layout_height="wrap_content" android:layout_width="wrap_content" android:text="Cinema" android:textColor="@color/text_label" android:textSize="10sp"/>
                <TextView android:layout_height="wrap_content" android:layout_width="wrap_content" android:text="Stars" android:textColor="@color/text_white" android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/card_mid"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tickets"
            android:textColor="@color/text_white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:id="@+id/llTicketsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Snacks"
            android:textColor="@color/text_white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:id="@+id/llSnacksContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="32dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/card_mid"
            android:layout_marginBottom="32dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="40dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="TOTAL PAID"
                android:textColor="@color/text_dimmed"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvFinalTotalPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$0.00"
                android:textColor="@color/price_green"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <Button

            android:id="@+id/btnSendTicket"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="@color/brand_red"
            android:text="Share Ticket"
            android:textColor="@color/text_white"
            android:textStyle="bold"
            android:textSize="16sp" />

    </LinearLayout>
</ScrollView>

